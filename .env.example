# Copy this file to .env and fill in your own values. Never commit real secrets.

# --- LLM (chat) ---
# Provider for the analytics agent's chat model: openai | claude | kimi | openrouter
LLM_PROVIDER=openai
# Model id for the chosen provider, e.g.
#   openai      -> gpt-4.1-mini
#   claude      -> claude-sonnet-4-6
#   kimi        -> moonshot-v1-128k
#   openrouter  -> anthropic/claude-sonnet-4-6
LLM_MODEL=gpt-4.1-mini
# API key for the chosen provider. If unset, falls back to the provider's standard env var
# (OPENAI_API_KEY / ANTHROPIC_API_KEY / MOONSHOT_API_KEY / OPENROUTER_API_KEY).
LLM_API_KEY=
# Optional custom base URL (auto-set for kimi/openrouter; leave blank otherwise).
LLM_BASE_URL=
# Enable task-level model routing from MODEL_PROFILE_PATH. When false, all chat
# calls use LLM_PROVIDER + LLM_MODEL.
MODEL_ROUTING_ENABLED=false
MODEL_PROFILE_PATH=model_profiles.yml

# --- Provider keys ---
OPENAI_API_KEY=sk-your-openai-key
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key
MOONSHOT_API_KEY=
OPENROUTER_API_KEY=

# --- Embeddings (stays on OpenAI) ---
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# --- Vector store ---
QDRANT_URL=https://your-cluster.qdrant.io
QDRANT_API_KEY=your-qdrant-api-key
QDRANT_COLLECTION_NAME=dbt_semantic_dictionary

# --- Query backend: duckdb (default, local) | bigquery ---
BACKEND=duckdb

# --- DuckDB backend ---
# Path (from repo root) to the DuckDB database file dbt builds. Must match the
# `path:` in zerve_transform/profiles.yml (which is relative to the dbt project dir).
DUCKDB_PATH=zerve_transform/zerve.duckdb
DUCKDB_SCHEMA=main

# --- BigQuery backend (optional backup) ---
GOOGLE_APPLICATION_CREDENTIALS=zerve_transform/your-service-account.json
BIGQUERY_PROJECT=your-gcp-project
BIGQUERY_DATASET=zerveevents
BIGQUERY_LOCATION=us-east5

# --- Autonomous agent ---
# Max sub-queries the agent runs per question (planned + reflection follow-ups).
# Bounds runtime and LLM/warehouse cost.
MAX_SUB_QUERIES=8
